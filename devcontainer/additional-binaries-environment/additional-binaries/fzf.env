## Install strategy enum: tar | zip | deb.
INSTALL_METHOD=tar

## For tar installs: "binary" copies only one executable, "tree" installs full extracted directory.
TAR_INSTALL_MODE=binary

## GitHub repository in owner/repo format.
REPO=junegunn/fzf

## Prefix prepended to VERSION when constructing the GitHub release tag.
## Example: prefix=v and version=0.67.0 -> tag=v0.67.0.
GITHUB_VERSION_TAG_PREFIX=v

## amd64 release asset filename template. Supported placeholders: {VERSION}, {TAG}.
## Fictional example using both placeholders: fzf-{VERSION}-{TAG}-linux_amd64.tar.gz -> fzf-1.2.3-v1.2.3-linux_amd64.tar.gz.
ASSET_FILE_NAME_AMD64=fzf-{VERSION}-linux_amd64.tar.gz

## arm64 release asset filename template. Supported placeholders: {VERSION}, {TAG}.
## Fictional example using both placeholders: fzf-{VERSION}-{TAG}-linux_arm64.tar.gz -> fzf-1.2.3-v1.2.3-linux_arm64.tar.gz.
ASSET_FILE_NAME_ARM64=fzf-{VERSION}-linux_arm64.tar.gz

## Executable path relative to extracted content or installed tree.
TAR_BIN_PATH=fzf

## Extracted root directory glob inside tar (used only when TAR_INSTALL_MODE=tree).
TAR_INSTALL_ROOT_GLOB=

## Absolute destination directory for extracted tree (used only when TAR_INSTALL_MODE=tree).
TAR_INSTALL_DIR=

## Absolute destination path for installed executable.
INSTALL_TARGET_PATH=/usr/local/bin/fzf
